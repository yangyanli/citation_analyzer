# Citation Analyzer Configuration Template
# Copy this file to '.env' and fill in your actual API keys.
# DO NOT COMMIT actual keys to version control.

# Semantic Scholar API Key (Required for fast citation collection and context parsing)
# Apply for one here: https://www.semanticscholar.org/product/api
S2_API_KEY=your_semantic_scholar_api_key_here

# Gemini API Key (Required for AI sentiment analysis and criteria generation)
# Get yours here: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here
